<script>
(function(){
  // ---------- Config ----------
  var REDIRECT_URL = "https://zd.lc/7OVqY"; // <-- REDIRECT_URL: where users go after submit
  var form = document.getElementById("mc-form");
  var MC_ACTION = form.getAttribute("data-mc-action");

  // year
  document.getElementById("yr").textContent = new Date().getFullYear();

  // ---------- Sticky mobile CTA ----------
  var sticky = document.getElementById("sticky");
  var hero = document.getElementById("signup");
  function onScroll(){
    var r = hero.getBoundingClientRect();
    // show sticky once the hero form is mostly out of view
    if (r.bottom < 40) sticky.classList.add("show");
    else sticky.classList.remove("show");
  }
  window.addEventListener("scroll", onScroll, { passive:true });
  onScroll();

  // ---------- Validation ----------
  var emailInput = document.getElementById("EMAIL");
  var emailField = document.getElementById("f-email");
  var EMAIL_RE = /^[^\s@]+@[^\s@]+\.[^\s@]{2,}$/;

  function validate(){
    var ok = EMAIL_RE.test(emailInput.value.trim());
    emailField.classList.toggle("invalid", !ok);
    return ok;
  }
  emailInput.addEventListener("input", function(){
    if (emailField.classList.contains("invalid")) validate();
  });

  // ---------- Submit ----------
  // We submit to Mailchimp's JSONP endpoint so we keep the user on this page
  // and can control the redirect ourselves. (?u=&id=&EMAIL=&FNAME=&c=callback)
  // If JSONP is blocked, we fall back to fetch(no-cors) so the lead still
  // reaches Mailchimp, then redirect either way.
  form.addEventListener("submit", function(e){
    e.preventDefault();
    if (!validate()) { emailInput.focus(); return; }

    var btn = form.querySelector(".cta");
    var label = btn.querySelector(".label");
    btn.setAttribute("disabled","disabled");
    var prev = label.textContent;
    label.textContent = "One sec…";

    var email = encodeURIComponent(emailInput.value.trim());
    var fname = encodeURIComponent((document.getElementById("FNAME").value || "").trim());
    var hp = encodeURIComponent(form.querySelector('input[name^="b_"]').value || "");
    var hpName = form.querySelector('input[name^="b_"]').name;

    // Switch Mailchimp's /post -> /post-json for JSONP
    var jsonpUrl = MC_ACTION.replace("/post?","/post-json?")
      + "&EMAIL=" + email
      + "&FNAME=" + fname
      + "&" + hpName + "=" + hp
      + "&c=mcCallback_" + Date.now();

    var done = false;
    function finish(){
      if (done) return; done = true;
      window.location.href = REDIRECT_URL;
    }

    // JSONP
    var cbName = "mcCallback_" + Date.now();
    window[cbName] = function(){ finish(); };
    jsonpUrl = jsonpUrl.replace(/&c=mcCallback_\d+/, "&c=" + cbName);

    var s = document.createElement("script");
    s.src = jsonpUrl;
    s.onerror = function(){
      // Fallback: fire-and-forget POST, then redirect
      try {
        var fd = new FormData(form);
        fetch(MC_ACTION, { method:"POST", body:fd, mode:"no-cors" }).finally(finish);
      } catch(_) { finish(); }
    };
    document.head.appendChild(s);

    // Safety net: redirect after 2.5s no matter what
    setTimeout(finish, 2500);

    // Restore label if somehow user stays
    setTimeout(function(){
      btn.removeAttribute("disabled");
      label.textContent = prev;
    }, 4000);
  });
})();
</script>
